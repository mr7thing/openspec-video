# OpenSpec-Video 环境变量示例
# 复制此文件为 .env 并填入实际值

# 守护进程端口
OPSV_DAEMON_PORT=3061

# Review 服务端口
OPSV_REVIEW_PORT=3062

# API Keys（根据实际使用的 provider 配置）
SEADREAM_API_KEY=your_seadream_api_key_here
SILICONFLOW_API_KEY=your_siliconflow_api_key_here
MINIMAX_API_KEY=your_minimax_api_key_here
RUNNINGHUB_API_KEY=your_runninghub_api_key_here
VOLCENGINE_API_KEY=your_volcengine_api_key_here

# 调试模式
OPSV_DEBUG=false
