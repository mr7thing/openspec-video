{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://openspec-video.dev/schemas/project-config-0.3.2.json",
  "title": "OpenSpec-Video Project Configuration Schema",
  "description": "Schema for validating project.md configuration files in OpsV 0.3.2",
  "version": "0.3.2",
  "type": "object",
  "required": ["name", "aspect_ratio", "resolution", "schema_version"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Project name"
    },
    "version": {
      "type": "string",
      "default": "0.1.0",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Project version following semver"
    },
    "description": {
      "type": "string",
      "maxLength": 500,
      "description": "Brief project description"
    },
    "aspect_ratio": {
      "type": "string",
      "enum": ["16:9", "9:16", "1:1", "21:9", "4:3", "2.39:1"],
      "description": "Default aspect ratio for all outputs"
    },
    "resolution": {
      "type": "string",
      "enum": ["480p", "1080p", "2K", "4K", "8K"],
      "description": "Default resolution quality"
    },
    "engine": {
      "type": "string",
      "enum": ["wan2.2", "veo", "luma", "sora", "comfyui", "auto"],
      "description": "Preferred generation engine"
    },
    "global_style_postfix": {
      "type": "string",
      "maxLength": 500,
      "description": "Style suffix appended to all English prompts"
    },
    "vision": {
      "type": "string",
      "maxLength": 1000,
      "description": "Vision statement for first task context"
    },
    "style": {
      "type": "object",
      "properties": {
        "visual_style": {
          "type": "string",
          "description": "Overall visual style (e.g., 'cinematic noir')"
        },
        "genre": {
          "type": "string",
          "description": "Genre (e.g., 'sci-fi', 'fantasy')"
        },
        "palette": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Primary color palette"
        },
        "references": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Reference works (movies, artworks)"
        }
      }
    },
    "technical": {
      "type": "object",
      "properties": {
        "default_image_format": {
          "type": "string",
          "enum": ["png", "jpg", "webp"],
          "default": "png"
        },
        "default_video_duration": {
          "type": "string",
          "pattern": "^\\d+s$",
          "default": "5s"
        },
        "batch_size": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10,
          "default": 1
        },
        "retry_attempts": {
          "type": "integer",
          "minimum": 0,
          "maximum": 5,
          "default": 3
        },
        "concurrency": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5,
          "default": 1
        }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "schema_version": {
      "type": "string",
      "enum": ["0.3.0", "0.3.1", "0.3.2"],
      "default": "0.3.2"
    }
  },
  "additionalProperties": false
}
