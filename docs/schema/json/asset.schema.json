{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://openspec-video.dev/schemas/asset-0.3.2.json",
  "title": "OpenSpec-Video Asset Schema",
  "description": "Schema for validating character, scene, and prop assets in OpsV 0.3.2",
  "version": "0.3.2",
  "definitions": {
    "visualTraits": {
      "type": "object",
      "properties": {
        "age_group": { "type": "string" },
        "gender": { "type": "string" },
        "build": { "type": "string" },
        "skin_tone": { "type": "string" },
        "eye_color": { "type": "string" },
        "hair_style": { "type": "string" },
        "hair_color": { "type": "string" },
        "clothing": { "type": "string" },
        "accessories": {
          "type": "array",
          "items": { "type": "string" }
        },
        "distinctive_features": {
          "type": "array",
          "items": { "type": "string" }
        },
        "default_expression": { "type": "string" }
      }
    },
    "atmosphere": {
      "type": "object",
      "required": ["mood"],
      "properties": {
        "mood": { "type": "string" },
        "color_palette": {
          "type": "array",
          "items": { "type": "string" }
        },
        "lighting": { "type": "string" },
        "light_sources": {
          "type": "array",
          "items": { "type": "string" }
        },
        "atmospheric_effects": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "physicalProperties": {
      "type": "object",
      "properties": {
        "material": {
          "type": "array",
          "items": { "type": "string" }
        },
        "size": { "type": "string" },
        "weight": { "type": "string" },
        "condition": { "type": "string" }
      }
    },
    "referenceStatus": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": ["draft", "confirmed", "rejected"]
          },
          "source": { "type": "string" },
          "prompt": { "type": "string" }
        },
        "required": ["status"]
      }
    }
  },
  "type": "object",
  "required": ["name", "type", "has_image"],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^@[a-zA-Z][a-zA-Z0-9_]*$",
      "description": "Asset identifier starting with @"
    },
    "type": {
      "type": "string",
      "enum": ["character", "scene", "prop", "costume", "vehicle", "weapon", "creature", "fx"]
    },
    "display_name": { "type": "string" },
    "has_image": {
      "type": "boolean",
      "description": "Whether this asset has confirmed reference images"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "confirmed", "deprecated", "archived"],
      "default": "draft"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "author": { "type": "string" },
    "schema_version": {
      "type": "string",
      "default": "0.3.2"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "reference_images": {
      "type": "array",
      "items": { "type": "string" }
    },
    "reference_status": {
      "$ref": "#/definitions/referenceStatus"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "type": { "const": "character" } }
      },
      "then": {
        "properties": {
          "role": {
            "type": "string",
            "enum": ["protagonist", "antagonist", "supporting", "background"]
          },
          "backstory": { "type": "string" },
          "personality": {
            "type": "array",
            "items": { "type": "string" }
          },
          "visual_traits": {
            "$ref": "#/definitions/visualTraits"
          }
        }
      }
    },
    {
      "if": {
        "properties": { "type": { "const": "scene" } }
      },
      "then": {
        "properties": {
          "scene_type": {
            "type": "string",
            "enum": ["interior", "exterior", "transitional"]
          },
          "time_of_day": {
            "type": "string",
            "enum": ["dawn", "morning", "noon", "afternoon", "dusk", "night", "midnight"]
          },
          "weather": { "type": "string" },
          "location": { "type": "string" },
          "atmosphere": {
            "$ref": "#/definitions/atmosphere"
          },
          "environment_details": {
            "type": "object",
            "properties": {
              "architecture": { "type": "string" },
              "key_objects": {
                "type": "array",
                "items": { "type": "string" }
              },
              "textures": {
                "type": "array",
                "items": { "type": "string" }
              },
              "condition": { "type": "string" }
            }
          },
          "audio_notes": {
            "type": "object",
            "properties": {
              "ambient": {
                "type": "array",
                "items": { "type": "string" }
              },
              "musical_mood": { "type": "string" }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": { "type": { "const": "prop" } }
      },
      "then": {
        "properties": {
          "prop_category": {
            "type": "string",
            "enum": ["weapon", "tool", "vehicle", "furniture", "wearable", "consumable", "misc"]
          },
          "significance": {
            "type": "string",
            "enum": ["key", "supporting", "background"]
          },
          "physical_properties": {
            "$ref": "#/definitions/physicalProperties"
          },
          "visual_description": {
            "type": "object",
            "properties": {
              "shape": { "type": "string" },
              "color": { "type": "string" },
              "decorations": {
                "type": "array",
                "items": { "type": "string" }
              },
              "effects": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          },
          "associated_characters": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^@[a-zA-Z][a-zA-Z0-9_]*$"
            }
          },
          "associated_scenes": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^@[a-zA-Z][a-zA-Z0-9_]*$"
            }
          },
          "narrative_function": { "type": "string" }
        }
      }
    },
    {
      "if": {
        "properties": { "has_image": { "const": true } }
      },
      "then": {
        "required": ["reference_images"],
        "properties": {
          "reference_images": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          }
        }
      }
    }
  ]
}
