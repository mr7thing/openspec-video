# OpenSpec-Video 环境变量配置 (v0.5.2)
# 复制此文件为 .env 并填入你的 API 密钥

# ============================================
# 火山引擎 (SeaDream / Seedance)
# 获取地址: https://www.volcengine.com/ark
# ============================================
# 0.5.1+ 版本统一使用此 Key 进行火山引擎鉴权
VOLCENGINE_API_KEY=your_volcengine_api_key_here

# ============================================
# SiliconFlow (Wan 2.1 等)
# 获取地址: https://siliconflow.cn
# ============================================
SILICONFLOW_API_KEY=your_siliconflow_api_key_here

# ============================================
# MiniMax (图像 01 / 海螺视频)
# 获取地址: https://platform.minimaxi.com/
# ============================================
MINIMAX_API_KEY=your_minimax_api_key_here

# ============================================
# Google Gemini (用于 Agent 对话与构思)
# ============================================
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================
# 框架配置
# ============================================
# 日志级别: error, warn, info, http, verbose, debug, silly
LOG_LEVEL=info
# 调试模式: 设置为 true 启用详细 API 载荷输出
OPSV_DEBUG=false
