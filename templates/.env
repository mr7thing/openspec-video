# OpsV v0.8 环境变量配置
# 复制此文件为 .opsv/.env 并填入你的 API 密钥

# ============================================
# 火山引擎 (SeaDream / Seedance)
# 获取地址: https://www.volcengine.com/ark
# ============================================
ARK_API_KEY=your_ark_api_key_here

# ============================================
# SiliconFlow (Wan / Qwen-Image)
# 获取地址: https://siliconflow.cn
# ============================================
SILICONFLOW_API_KEY=your_siliconflow_api_key_here

# ============================================
# MiniMax (图像 / 海螺视频)
# 获取地址: https://platform.minimaxi.com/
# ============================================
MINIMAX_API_KEY=your_minimax_api_key_here

# ============================================
# RunningHub (ComfyUI Cloud)
# 获取地址: https://www.runninghub.cn
# ============================================
RUNNINGHUB_API_KEY=your_runninghub_api_key_here

# ============================================
# 框架配置
# ============================================
# 日志级别: error, warn, info, http, verbose, debug, silly
LOG_LEVEL=info
# 调试模式
OPSV_DEBUG=false
