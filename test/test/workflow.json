{
    "workflows": {
        "characters": {
            "type": "asset_batch",
            "source": "videospec/assets/characters/*.md",
            "output_dir": "Project-mv/artifacts/characters",
            "prompt_template": "**Task**: Character Design Sheet\n**Style**: ${style}\n**Character**: ${name}\n**Description**:\n${description}\n\n**Output**: Three views (Front, Side, Back) and facial expressions.",
            "settings": {
                "aspect_ratio": "1:1",
                "quality": "2K"
            }
        },
        "scenes": {
            "type": "asset_batch",
            "source": "videospec/assets/scenes/*.md",
            "output_dir": "Project-mv/artifacts/scenes",
            "prompt_template": "**Task**: Environment Concept Art\n**Style**: ${style}\n**Location**: ${name}\n**Description**:\n${description}",
            "settings": {
                "aspect_ratio": "16:9",
                "quality": "2K"
            }
        },
        "story": {
            "type": "storyboard",
            "source": "videospec/stories/Script.md",
            "output_dir": "Project-mv/artifacts/storyboard",
            "use_references": true,
            "settings": {
                "aspect_ratio": "16:9",
                "quality": "2K"
            }
        }
    }
}