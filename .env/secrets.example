# OpenSpec-Video 环境变量配置
# 复制此文件为 .env 并填入你的 API 密钥

# ============================================
# 图像生成 - SeaDream 5.0 Lite (火山引擎)
# 获取地址: https://www.volcengine.com/docs/82379/1824121
# ============================================
SEADREAM_API_KEY=your_seadream_api_key_here
# 或直接使用火山引擎主密钥
VOLCENGINE_API_KEY=your_volcengine_api_key_here

# ============================================
# 视频生成 - SiliconFlow
# 获取地址: https://siliconflow.cn
# ============================================
SILICONFLOW_API_KEY=your_siliconflow_api_key_here

# ============================================
# 可选：Google Gemini (用于 Agent 对话)
# ============================================
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================
# 日志级别
# 可选: error, warn, info, http, verbose, debug, silly
# ============================================
LOG_LEVEL=info

# ============================================
# 调试模式
# 设置为 true 启用详细日志输出
# ============================================
OPSV_DEBUG=false
